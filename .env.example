# ─────────────────────────────────────────────────────────────────────────────
# Amazon Product Recommender — environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq LLM ──────────────────────────────────────────────────────────────────
# Get your key at https://console.groq.com
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY
GROQ_MODEL=llama3-70b-8192

# ── Astra DB (Vector Store) ───────────────────────────────────────────────────
# Create a free Serverless (Vector) database at https://astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:YOUR_TOKEN
ASTRA_DB_API_ENDPOINT=https://YOUR-DB-ID-YOUR-REGION.apps.astra.datastax.com
ASTRA_DB_KEYSPACE=amazon_rag
ASTRA_DB_COLLECTION=products

# ── HuggingFace Embeddings ────────────────────────────────────────────────────
# Model is downloaded automatically on first run (or baked into the Docker image)
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Application ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
TOP_K_RESULTS=5

# ── Data Ingestion ────────────────────────────────────────────────────────────
# Download dataset: https://www.kaggle.com/datasets/karkavelrajaj/amazon-sales-dataset
AMAZON_DATASET_PATH=data/amazon_products.csv
INGEST_BATCH_SIZE=500
